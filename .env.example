# Blackjack Trainer Pro - configuration des ports et URLs

# Port du serveur de développement React (Vite)
VITE_PORT=5173

# Port du serveur Streamlit
STREAMLIT_PORT=8501

# URL du simulateur (bouton dans l'app React → ouvre Streamlit)
VITE_SIMULATOR_URL=http://localhost:8501

# URL du jeu (bouton dans Streamlit → ouvre l'app React)
STREAMLIT_GAME_URL=http://localhost:5173
